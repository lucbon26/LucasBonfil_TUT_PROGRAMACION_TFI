Algoritmo PiramideNumeros
	
    Definir altura Como Entero
    Definir i, j Como Entero
	
    Escribir "Ingrese la altura de la piramide:"
    Leer altura
	
    Escribir ""
	
    Para i <- 1 Hasta altura Hacer
		
        Para j <- 1 Hasta i Hacer
            Escribir Sin Saltar j, " "
        FinPara
		
        Escribir ""
		
    FinPara
	
FinAlgoritmo